{
    "_comment": "Prediction Market Bot Configuration",
    "_version": "1.0.0",
    "_updated": "2026-03-17",

    "trading": {
        "mode": "paper",
        "enable_learning": true,
        "starting_balance": 500.0,
        "scan_interval_ms": 2000
    },

    "entry": {
        "min_opportunity_score": 60,
        "price_velocity_threshold": 0.03,
        "velocity_window_seconds": 10,
        "spread_diff_threshold": 0.05,
        "max_gemini_volume": 30000,
        "min_match_confidence": 0.7,
        "max_concurrent_positions": 5,
        "max_per_category": 2
    },

    "position_sizing": {
        "kelly_multiplier": 0.15,
        "max_position_usd": 100.0,
        "min_position_usd": 5.0,
        "max_capital_at_risk_pct": 50
    },

    "exit": {
        "take_profit_buffer": 0.01,
        "stop_loss_width": 0.03,
        "max_hold_time_seconds": 600,
        "staleness_threshold_seconds": 300
    },

    "risk_management": {
        "max_drawdown_kill_switch_pct": 20,
        "daily_loss_limit_usd": -50,
        "max_single_trade_loss_alert_usd": -10,
        "min_orderbook_depth_usd": 50,
        "slippage_penalty": 0.005
    },

    "learning": {
        "cycle_interval_seconds": 30,
        "win_rate_aggressive_threshold": 0.65,
        "win_rate_conservative_threshold": 0.50,
        "avg_pnl_aggressive_threshold": 2.0,
        "param_adjustment_rate": 0.05
    },

    "api": {
        "polymarket_rpm": 30,
        "kalshi_rpm": 60,
        "gemini_rpm": 60,
        "cache_ttl_ms": 5000,
        "request_timeout_ms": 10000
    },

    "market_matching": {
        "min_confidence": 0.5,
        "rematch_interval_minutes": 5,
        "max_simulated_markets": 30
    },

    "server": {
        "port": 3003,
        "dashboard_refresh_ms": 5000
    },

    "_profiles": {
        "_comment": "Named session profiles. Activate via env vars — not loaded by the engine directly. These are reference values.",

        "short_horizon_v1": {
            "_description": "Short-session 15-minute operating profile. Use with AUTONOMOUS_15M_SESSION=true and TRADING_PROFILE=short-run.",
            "_env_vars": {
                "TRADING_PROFILE": "short-run",
                "AUTONOMOUS_15M_SESSION": "true",
                "SESSION_MIN_TTX_SECONDS": "600",
                "SESSION_MAX_TTX_SECONDS": "3600",
                "SESSION_ENTRY_BUFFER_SECONDS": "120",
                "SESSION_FORCE_EXIT_BUFFER_SECONDS": "60",
                "SESSION_MAX_CONCURRENT_LIVE": "2",
                "SESSION_DAILY_LOSS_LIMIT_USD": "3",
                "SESSION_PROFIT_TARGET_USD": "10",
                "SESSION_TIMEOUT_MS": "900000",
                "PRE_TRADE_GATE_CACHE_MS": "1000",
                "PRICE_UPDATE_INTERVAL_MS": "1000",
                "MATCH_INTERVAL_MS": "10000",
                "REF_BULK_REFRESH_INTERVAL_MS": "5000",
                "GEMINI_REAL_FETCH_INTERVAL_MS": "10000",
                "GEMINI_TICKER_FETCH_INTERVAL_MS": "1000",
                "CLEANUP_INTERVAL_MS": "60000",
                "SESSION_SPREAD_CAP": "0.08"
            },
            "_param_overrides": {
                "max_position_size": 10.0,
                "live_max_position_size": 10.0,
                "stop_loss_width": 0.06,
                "min_edge_live": 0.06,
                "hold_to_settlement": 0,
                "max_hold_time": 480,
                "pre_expiry_exit_seconds": 180
            },
            "_notes": [
                "TTX window is narrowed at source so long-dated contracts do not enter the active universe.",
                "15-minute timeout plus explicit entry and force-exit buffers create a real short-session lifecycle.",
                "Cadence defaults are tightened for faster short-horizon capture without changing non-session mode.",
                "Position caps are restored to a plausible economic range; viability still depends on measured edge and fill frequency.",
                "hold_to_settlement=0 because short-session trades must exit inside the session rather than wait for binary settlement."
            ]
        },

        "standard_v18": {
            "_description": "Standard V18 validated profile. Paper mode, all categories, settlement holds.",
            "_env_vars": {},
            "_param_overrides": {
                "stop_loss_width": 0.10,
                "max_hold_time": 14400,
                "hold_to_settlement": 1
            }
        }
    }
}
